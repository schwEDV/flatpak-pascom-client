{
    "app-id": "net.pascom.pascom_Client",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "pascom-apprun",
    "finish-args": [
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--share=network",
        "--share=ipc",
        "--device=all",
        "--talk-name=org.freedesktop.Notifications",
        "--filesystem=xdg-download",
        "--env=QT_QPA_PLATFORMTHEME=gtk3",
        "--env=QT_PLATFORMTHEME=gtk3"
    ],
    "modules": [
        {
            "name": "mit-krb5",
            "buildsystem": "simple",
            "build-commands": [
                "cd src && autoreconf -i",
                "cd src && ./configure --prefix=/app --disable-static --enable-shared",
                "cd src && make -j$(nproc)",
                "cd src && make install"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://kerberos.org/dist/krb5/1.21/krb5-1.21.3.tar.gz",
                    "sha256": "b7a4cd5ead67fb08b980b21abd150ff7217e85ea320c9ed0c6dadd304840ad35"
                }
            ]
        },
        {
            "name": "pascom-client",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/pascom_Client",
                "cp -a . /app/pascom_Client/",
                "rm -f /app/pascom_Client/pascom-apprun.sh /app/pascom_Client/net.pascom.pascom_Client.desktop /app/pascom_Client/net.pascom.pascom_Client.metainfo.xml",

                "rm -f /app/pascom_Client/lib/libssl.so /app/pascom_Client/lib/libssl.so.3",
                "rm -f /app/pascom_Client/lib/libcrypto.so /app/pascom_Client/lib/libcrypto.so.3",

                "rm -rf /app/pascom_Client/lib-ubuntu20",

                "install -Dm755 pascom-apprun.sh /app/bin/pascom-apprun",

                "install -Dm644 client.png /app/share/icons/hicolor/256x256/apps/net.pascom.pascom_Client.png",
                "install -Dm644 net.pascom.pascom_Client.desktop /app/share/applications/net.pascom.pascom_Client.desktop",
                "install -Dm644 net.pascom.pascom_Client.metainfo.xml /app/share/metainfo/net.pascom.pascom_Client.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.pascom.net/release-archive/client/cloud/pascom_Client-120.R5110-linux.tar.bz2",
                    "sha256": "0fdf586a4a7d8af3c28296f21a76b7539857806d66ba52953d30840af2df8486"
                },
                {
                    "type": "file",
                    "path": "pascom-apprun.sh"
                },
                {
                    "type": "file",
                    "path": "net.pascom.pascom_Client.desktop"
                },
                {
                    "type": "file",
                    "path": "net.pascom.pascom_Client.metainfo.xml"
                }
            ]
        }
    ]
}
